# ─────────────────────────────────────────────────────────────────────────────
#  ALGEONEX AI Video Bot — Ortam Değişkenleri
# ─────────────────────────────────────────────────────────────────────────────

# KIE.AI API Key — TTS + Veo3 video üretimi için zorunlu
KIE_API_KEY=your_kie_api_key_here

# Telegram Bot Token (@BotFather'dan alınır)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Webhook URL — Coolify'ın atadığı public URL (boşsa polling modu)
# WEBHOOK_URL=https://your-app.example.com

# Render dizini — container içinde volume mount (Coolify: /data/renders)
ALGEONEX_RENDER_DIR=/data/renders

# OpenAI API Key — TTS script rewriter için (GPT-4o)
OPENAI_API_KEY=your_openai_api_key_here

# ElevenLabs fallback (KIE API yoksa)
# ELEVENLABS_API_KEY=your_elevenlabs_key_here
ELEVENLABS_VOICE_ID=pMsXgVXv3BLzUgSXRplE

# Port (varsayılan: 3000)
PORT=3000
